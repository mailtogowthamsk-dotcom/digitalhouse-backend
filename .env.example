NODE_ENV=development
PORT=4000
# When cPanel Node receives full path (not stripped by Apache proxy):
# API_BASE_PATH=/digitalhouse/backend

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=digital_house
DB_USER=root
DB_PASSWORD=

JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_EXPIRES_IN=7d

# Google Sign-In (mobile additional login — does not replace OTP)
# Web client ID is required for token verification; add iOS/Android client IDs from Google Cloud Console
# GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_IOS_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_ANDROID_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_ID= (alias for web client if only one is set)

OTP_HASH_PEPPER=change_me_otp_pepper
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# SMTP (transactional mail: OTP, approvals)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
# Sender: plain email or "Display Name <no-reply@yourdomain.com>"
SMTP_FROM="Digital House <no-reply@yourdomain.com>"
# Encryption: tls (STARTTLS, port 587) | ssl (SMTPS, port 465) | none
SMTP_ENCRYPTION=tls
# Legacy alternative to SMTP_ENCRYPTION=ssl
# SMTP_SECURE=false

# Expo push (optional — improves rate limits; from expo.dev project credentials)
EXPO_ACCESS_TOKEN=

# Direct FCM (optional — for non-Expo native tokens). JSON string or file path:
# FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_SERVICE_ACCOUNT_PATH=

# Razorpay (matrimony subscriptions + contact reveal)
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=whsec_...
# Dev-only subscribe/confirm (default: off in production and when Razorpay keys exist)
# MATRIMONY_ALLOW_DEV_PAYMENTS=true

# Matrimony platform pricing (admin can also override via PUT /admin/matrimony/platform-settings)
# MATRIMONY_GOLD_PRICE_INR=999
# MATRIMONY_PLATINUM_PRICE_INR=1999
# MATRIMONY_CONTACT_REVEAL_PAISE=50000
# MATRIMONY_MONTHLY_OPEN_QUOTA=30
# MATRIMONY_PLAN_DURATION_MONTHS=12

# Admin panel (API only): set X-Admin-Key header to this value
ADMIN_API_KEY=your_admin_api_key_here

# Admin login (whitelist): comma-separated emails; single shared password
ADMIN_EMAILS=admin@digitalhouse.com
ADMIN_PASSWORD=change_me_admin_password
JWT_ADMIN_EXPIRES_IN=24h

# Orphan PENDING media cleanup (R2 + media_files). Default: on, hourly, >24h old.
# MEDIA_ORPHAN_CLEANUP_ENABLED=true
# MEDIA_ORPHAN_CLEANUP_INTERVAL_MS=3600000
# MEDIA_ORPHAN_CLEANUP_HOURS=24
# MEDIA_ORPHAN_CLEANUP_BATCH=100
