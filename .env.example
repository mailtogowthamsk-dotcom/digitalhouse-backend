NODE_ENV=development
PORT=4000
# When cPanel Node receives full path (not stripped by Apache proxy):
# API_BASE_PATH=/digitalhouse/backend

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=digital_house
DB_USER=root
DB_PASSWORD=

JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_EXPIRES_IN=7d

OTP_HASH_PEPPER=change_me_otp_pepper
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# SMTP (transactional mail: OTP, approvals)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
# Sender: plain email or "Display Name <no-reply@yourdomain.com>"
SMTP_FROM="Digital House <no-reply@yourdomain.com>"
# Encryption: tls (STARTTLS, port 587) | ssl (SMTPS, port 465) | none
SMTP_ENCRYPTION=tls
# Legacy alternative to SMTP_ENCRYPTION=ssl
# SMTP_SECURE=false

# Admin panel (API only): set X-Admin-Key header to this value
ADMIN_API_KEY=your_admin_api_key_here

# Admin login (whitelist): comma-separated emails; single shared password
ADMIN_EMAILS=admin@digitalhouse.com
ADMIN_PASSWORD=change_me_admin_password
JWT_ADMIN_EXPIRES_IN=24h
