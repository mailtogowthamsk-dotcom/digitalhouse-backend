{
  "name": "digital-house-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "generate-admin-key": "node scripts/generate-admin-key.js",
    "optimize-media": "ts-node --transpile-only scripts/optimize-existing-media.ts",
    "optimize-media:dry": "ts-node --transpile-only scripts/optimize-existing-media.ts --dry-run",
    "db:fix-indexes": "node scripts/fix-duplicate-indexes.js",
    "db:migrate-media": "node scripts/migrate-media-files-columns.js",
    "db:migrate-posts-media": "node scripts/migrate-posts-media-columns.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 stop digitalhouse-api",
    "pm2:logs": "pm2 logs digitalhouse-api --lines 100",
    "pm2:deploy": "bash deploy/pm2-deploy.sh",
    "install:deps": "bash deploy/npm-install-deps.sh",
    "verify:deploy": "node -e \"require('fs').accessSync('dist/server.js'); require('express'); require('cors'); console.log('dist/server.js OK, dependencies installed');\"",
    "db:verify-matrimony": "node scripts/verify-matrimony-schema.js",
    "db:run-matrimony-sql": "node scripts/run-matrimony-sql.js",
    "db:run-notifications-sql": "node scripts/run-notifications-migration.js",
    "db:run-matrimony-razorpay-sql": "node scripts/run-matrimony-razorpay-migration.js",
    "db:run-matrimony-subscription-p1-sql": "node scripts/run-matrimony-subscription-p1-migration.js",
    "db:run-auth-google-sql": "node scripts/run-auth-google-migration.js",
    "db:run-jobs-phase2-sql": "node scripts/run-jobs-phase2-migration.js",
    "db:run-jobs-phase3-sql": "node scripts/run-jobs-phase3-migration.js",
    "db:run-marketplace-phase1-sql": "node scripts/run-marketplace-phase1-migration.js",
    "db:run-marketplace-phase3-sql": "node scripts/run-marketplace-phase3-migration.js",
    "db:run-marketplace-polish-sql": "node scripts/run-marketplace-polish-sql.js",
    "db:run-helping-hands-phase1-sql": "node scripts/run-helping-hands-phase1-sql.js",
    "db:run-helping-hands-lifecycle-sql": "node scripts/run-helping-hands-lifecycle-migration.js",
    "db:run-master-data-phase1-sql": "node scripts/run-master-data-phase1-sql.js",
    "db:run-reports-phase1-sql": "node scripts/run-reports-phase1-sql.js",
    "db:run-platform-management-sql": "node scripts/run-platform-management-sql.js",
    "db:run-production-hardening-sql": "node scripts/run-production-hardening-sql.js",
    "db:run-explore-hashtags-sql": "node scripts/run-explore-hashtags-migration.js",
    "db:run-post-visibility-sql": "node scripts/run-post-visibility-migration.js",
    "db:seed-master-data": "node scripts/seed-master-data.cjs",
    "db:backfill-master-data-users": "node scripts/backfill-master-data-users.cjs",
    "test:e2e-marketplace": "node scripts/run-e2e-marketplace.cjs",
    "test:e2e-jobs": "node scripts/run-e2e-jobs.cjs",
    "test:e2e-helping-hands": "node scripts/run-e2e-helping-hands.cjs",
    "db:apply-changes-requested": "node scripts/apply-matrimony-changes-requested.js",
    "verify:health": "node scripts/verify-production-health.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.980.0",
    "@aws-sdk/s3-request-presigner": "^3.980.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.7.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.3",
    "nodemailer": "^8.0.7",
    "razorpay": "^2.9.6",
    "sequelize": "^6.37.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.15.1",
    "@types/nodemailer": "^8.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
